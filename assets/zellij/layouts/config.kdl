layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="compact-bar"
        }
        children
    }

    tab name="nix" cwd="~/utkarsh/nix/config"

    tab name="config" cwd="~/utkarsh/nix/config" focus=true

    tab name="nvim" cwd="~/.config/nvim"
}
